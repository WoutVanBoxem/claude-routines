{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PAT}",
        "X-MCP-Readonly": "true",
        "X-MCP-Toolsets": "pull_requests,issues,repos"
      }
    },
    "workboard": {
      "type": "http",
      "url": "${WORKBOARD_URL}",
      "headers": { "Authorization": "Bearer ${WORKBOARD_TOKEN}" }
    }
  }
}
